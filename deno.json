{
  "name": "@redvars/log",
  "version": "0.2.0",
  "exports": "./mod.ts",
  "tasks": {
    "coverage:unit": "deno task test --coverage=./dist/coverage && deno coverage --include=src --lcov ./dist/coverage > ./dist/coverage/lcov.info",
    "coverage": "deno task coverage:unit",
    "test": "deno test --allow-read --allow-write --allow-env"
  },
  "exclude": ["dist", ".run", ".github/", "version.json"],
  "publish": {
    "exclude": ["test/", "examples/"]
  },
  "test": {
    "include": ["test/"]
  },
  "imports": {
    "@opentelemetry/api": "npm:@opentelemetry/api@^1.9.0",
    "@opentelemetry/api-logs": "npm:@opentelemetry/api-logs@^0.220.0",
    "@opentelemetry/core": "npm:@opentelemetry/core@^2.9.0",
    "@opentelemetry/resources": "npm:@opentelemetry/resources@^2.9.0",
    "@opentelemetry/sdk-logs": "npm:@opentelemetry/sdk-logs@^0.220.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0"
  }
}
